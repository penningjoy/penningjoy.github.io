---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Pull the three most recent posts to surface on the home page.
const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });

// Selected work, with the real stack surfaced as chips so the section
// rewards a closer look even before screenshots exist.
const work = [
  {
    title: 'BhriguOne',
    body: 'Building an open-source path for RL with verifiable rewards, aimed at real-world agents that need to run beyond the lab.',
    year: 'Now',
    live: true,
    tags: ['Reinforcement Learning', 'Verifiable Rewards', 'Open Source'],
  },
  {
    title: 'Industrial AI at Bhrigu',
    body: 'Owns a full-stack architecture spanning Go edge runtime, Python/ONNX inference, Kotlin services, NATS JetStream sync, and React.',
    year: '2025',
    tags: ['Go', 'Python · ONNX', 'Kotlin', 'NATS JetStream', 'React'],
  },
  {
    title: 'Software Products at E Tech Group',
    body: 'Led product development across pre-sales, customer onboarding, feature architecture, backlog strategy, and full-stack delivery.',
    year: '2021–25',
    tags: ['Product', 'Architecture', 'Full-stack'],
  },
  {
    title: 'AI and Engineering at Data-Core',
    body: 'Managed a 10-person engineering team delivering ML systems, web apps, APIs, data pipelines, and AI chatbots for enterprise clients.',
    year: '2018–21',
    tags: ['ML Systems', 'Data Pipelines', 'Team of 10'],
  },
];
---
<Base title="Joydeep Banerjee — Industrial AI Product Builder">

  <!-- ─── Hero ─── -->
  <section class="hero wrap">
    <div class="eyebrow reveal">
      <span class="label">Product</span>
      <span class="sep"></span>
      <span class="label">Industrial AI</span>
      <span class="sep"></span>
      <span class="label">Distributed Systems</span>
    </div>
    <h1 class="reveal" style="transition-delay:.06s">I build products.</h1>
    <p class="lede reveal" style="transition-delay:.12s">
      I have spent 15 years at the intersection of software engineering and
      industrial intelligence, building systems that learn, adapt, and operate
      on constrained, regulated, and air-gapped infrastructure.
    </p>
    <div class="meta reveal" style="transition-delay:.18s">
      <span class="label">Product Engineering</span>
      <span class="label">Machine Learning</span>
      <span class="label">Edge AI</span>
      <span class="label">Distributed Systems</span>
    </div>
  </section>

  <!-- ─── Work ─── -->
  <section id="work" class="wrap reveal">
    <div class="head">
      <span class="no">01</span>
      <h2>Selected work</h2>
    </div>
    <div class="work">
      {work.map((w, i) => (
        <article class="item">
          <span class="idx">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{w.title}</h3>
            <p>{w.body}</p>
            <div class="chips">
              {w.tags.map((t) => <span class="chip">{t}</span>)}
            </div>
          </div>
          <span class={`year${w.live ? ' live' : ''}`}>{w.year}</span>
        </article>
      ))}
    </div>
  </section>

  <!-- ─── Approach ─── -->
  <section id="approach" class="wrap reveal">
    <div class="head">
      <span class="no">02</span>
      <h2>How I build</h2>
    </div>
    <div class="tenets">
      <div class="tenet">
        <span class="n">i</span>
        <h3>Start with the operating reality</h3>
        <p>Industrial AI has to fit the factory floor, the network boundary, the validation process, and the people responsible when it fails.</p>
      </div>
      <div class="tenet">
        <span class="n">ii</span>
        <h3>Choose the right layer</h3>
        <p>Go for edge runtimes, Python and ONNX for inference, Kotlin for services, TypeScript for interfaces: each layer earns its tool.</p>
      </div>
      <div class="tenet">
        <span class="n">iii</span>
        <h3>Ship where compute is limited</h3>
        <p>The work is not just model quality. It is latency, observability, offline behavior, sync, deployment, and graceful recovery.</p>
      </div>
      <div class="tenet">
        <span class="n">iv</span>
        <h3>Bridge research and deployment</h3>
        <p>I care about the distance between promising papers and production systems, especially for RL agents and regulated AI workflows.</p>
      </div>
    </div>
  </section>

  <!-- ─── Writing (latest) ─── -->
  {posts.length > 0 && (
    <section id="latest" class="wrap reveal">
      <div class="head">
        <span class="no">03</span>
        <h2>Writing</h2>
      </div>
      <div class="work">
        {posts.map((post) => (
          <a class="item" href={`/writing/${post.id}`}>
            <span class="idx">→</span>
            <div>
              <h3>{post.data.title}<span class="arrow">→</span></h3>
              <p>{post.data.description}</p>
            </div>
            <span class="year">{fmt(post.data.date)}</span>
          </a>
        ))}
      </div>
      <p style="margin-top:1.5rem"><a href="/writing" class="label" style="color:var(--grey)">All writing →</a></p>
    </section>
  )}

  <!-- ─── About ─── -->
  <section id="about" class="wrap reveal">
    <div class="head">
      <span class="no">04</span>
      <h2>About</h2>
    </div>
    <div class="about">
      <span class="no"></span>
      <div class="body">
        <p><strong>I'm a product and engineering leader focused on applied AI.</strong>
        My work sits where software engineering, machine learning, and industrial operations meet.</p>
        <p>At Bhrigu, I lead full-stack technical work across edge systems, inference pipelines,
        mobile and backend services, cloud sync, and frontend product surfaces. Before that, I led
        software product development at E Tech Group and managed product engineering at Data-Core.</p>
        <p>I write and build around reinforcement learning for real-world agents, edge AI on
        constrained hardware, and NLP/AI for high-stakes environments like pharma and life sciences.</p>
      </div>
    </div>
  </section>

</Base>
